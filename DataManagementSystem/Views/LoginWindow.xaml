<Window x:Class="DataManagementSystem.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data Management System — Login"
        Width="900" Height="540"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        Background="{StaticResource SurfaceBrush}"
        AllowsTransparency="True">

    <Border CornerRadius="12" ClipToBounds="True"
            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" Opacity="0.15" BlurRadius="30"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Brand Panel -->
            <Border Grid.Column="0" Background="{StaticResource BrandGradient}">
                <StackPanel VerticalAlignment="Center" Margin="40">
                    <Border Width="72" Height="72" CornerRadius="18"
                            Background="#22FFFFFF" HorizontalAlignment="Left" Margin="0,0,0,28">
                        <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="34" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="DMS" Foreground="White"
                               FontSize="30" FontWeight="Bold" FontFamily="Segoe UI"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Data Management System"
                               Foreground="#99FFFFFF" FontSize="13" FontFamily="Segoe UI"
                               Margin="0,0,0,32"/>

                    <Border Height="1" Background="#22FFFFFF" Margin="0,0,40,28"/>

                    <TextBlock Foreground="#88FFFFFF" FontSize="12" FontFamily="Segoe UI"
                               TextWrapping="Wrap" LineHeight="20"
                               Text="Industrial data capture with PLC integration. Secure, offline, and reliable."/>

                    <TextBlock Text="v1.0.0" Foreground="#55FFFFFF" FontSize="11"
                               FontFamily="Segoe UI" Margin="0,24,0,0"/>
                </StackPanel>
            </Border>

            <!-- RIGHT: Login Form -->
            <Grid Grid.Column="1" Background="White">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Window controls -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right"
                            Margin="0,4,4,0">
                    <Button Content="&#xE949;" Style="{StaticResource WindowControlButton}"
                            Foreground="{StaticResource SubtleTextBrush}"
                            Click="Minimize_Click"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseWindowButton}"
                            Foreground="{StaticResource SubtleTextBrush}"
                            Click="Close_Click"/>
                </StackPanel>

                <!-- Form -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="48,0">
                    <TextBlock Text="Welcome back" FontSize="24" FontWeight="Bold"
                               FontFamily="Segoe UI" Foreground="{StaticResource DarkTextBrush}"
                               Margin="0,0,0,4"/>
                    <TextBlock Text="Sign in to continue"
                               FontSize="13" FontFamily="Segoe UI"
                               Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,0,0,36"/>

                    <TextBlock Text="USERNAME" Style="{StaticResource InputLabel}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleTextBrush}"/>
                    <Grid Margin="0,0,0,20">
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="38,10,12,10" Tag="Enter username"/>
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <TextBlock Text="PASSWORD" Style="{StaticResource InputLabel}"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource SubtleTextBrush}"/>
                    <Grid Margin="0,0,0,28">
                        <PasswordBox x:Name="PasswordBox" Padding="38,10,12,10"
                                     KeyDown="PasswordBox_KeyDown"/>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                   Foreground="{StaticResource SubtleTextBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <Button Content="Sign In" Style="{StaticResource PrimaryButton}"
                            HorizontalAlignment="Stretch" Padding="0,14" FontSize="14"
                            Command="{Binding LoginCommand}" Click="SignIn_Click"/>

                    <Border Margin="0,16,0,0" Padding="12,10" CornerRadius="8" Background="#FEF2F2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasMessage}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Message}" Foreground="{StaticResource DangerBrush}"
                                   FontSize="12" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>

                <!-- Footer -->
                <Border Grid.Row="2" Padding="24,12">
                    <TextBlock Text="{Binding CopyrightYear}"
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource SubtleTextBrush}"
                               HorizontalAlignment="Right"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
