<Window x:Class="DataManagementSystem.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="License Activation — Data Management System"
        Width="640" Height="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="{StaticResource SurfaceBrush}"
        AllowsTransparency="True">

    <Border CornerRadius="12" ClipToBounds="True"
            BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="0" Opacity="0.15" BlurRadius="30"/>
        </Border.Effect>
        <Grid Background="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{StaticResource BrandGradient}" Padding="24,16">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="License Activation" FontSize="16" FontWeight="SemiBold"
                                   Foreground="White" FontFamily="Segoe UI"/>
                        <TextBlock Text="Data Management System" FontSize="12"
                                   Foreground="#99FFFFFF" FontFamily="Segoe UI"/>
                    </StackPanel>

                    <Button Content="&#xE8BB;" Style="{StaticResource CloseWindowButton}"
                            HorizontalAlignment="Right" Margin="auto,0,0,0"
                            Click="Close_Click"/>
                </StackPanel>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="32,24">
                <!-- Machine ID -->
                <TextBlock Text="YOUR MACHINE ID" Style="{StaticResource InputLabel}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,6"/>
                <Border Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,24">
                    <Grid>
                        <TextBlock x:Name="MachineIdText"
                                   FontFamily="Consolas" FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource AccentBrush}"
                                   VerticalAlignment="Center"/>
                        <Button Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Right" ToolTip="Copy to clipboard"
                                Click="CopyMachineId_Click"/>
                    </Grid>
                </Border>

                <!-- License Key -->
                <TextBlock Text="ENTER LICENSE KEY" Style="{StaticResource InputLabel}"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,6"/>
                <TextBox x:Name="LicenseKeyBox" Height="80" TextWrapping="Wrap"
                         AcceptsReturn="False" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" FontSize="12"
                         Tag="Paste license key here (V1.xxxxx.xxxxx)"
                         Margin="0,0,0,8"/>

                <!-- Status -->
                <TextBlock x:Name="StatusText" FontSize="12" FontFamily="Segoe UI"
                           TextWrapping="Wrap" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="2" Padding="24,16" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <TextBlock Text="Contact Braentech Software for your license key."
                               FontSize="11" FontFamily="Segoe UI"
                               Foreground="{StaticResource SubtleTextBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource SecondaryButton}"
                                Padding="20,10" Margin="0,0,8,0" Click="Cancel_Click"/>
                        <Button Content="Activate" Style="{StaticResource PrimaryButton}"
                                Padding="20,10" Click="Activate_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
