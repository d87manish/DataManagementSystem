<Window x:Class="DataManagementSystem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DataManagementSystem.ViewModels"
        xmlns:views="clr-namespace:DataManagementSystem.Views"
        Title="Data Management System"
        WindowState="Maximized"
        WindowStyle="None"
        Background="{StaticResource SurfaceBrush}"
        AllowsTransparency="False">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DataCaptureViewModel}">
            <views:DataCapturePage/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ViewDataViewModel}">
            <views:ViewDataPage/>
        </DataTemplate>

        <!-- Nav button style -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Margin="8,2"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="{StaticResource BrandGradient}" Padding="16,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="&#xE8A0;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                               Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="DATA MANAGEMENT SYSTEM" FontSize="13" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,16,0">
                        <Run Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                             Foreground="#AAFFFFFF"/>
                        <Run Text=" " />
                        <Run Text="{Binding UserDisplay, Mode=OneWay}" FontFamily="Segoe UI" FontSize="12"
                             Foreground="#CCFFFFFF"/>
                    </TextBlock>

                    <Button Content="&#xE8FB;  Logout" Style="{StaticResource LogoutButton}"
                            FontFamily="Segoe UI" FontSize="12" Padding="12,6"
                            Command="{Binding LogoutCommand}"/>

                    <Button Content="&#xE921;" Style="{StaticResource WindowControlButton}"
                            Click="Minimize_Click" Margin="8,0,0,0" ToolTip="Minimize"/>
                    <Button Content="&#xE922;" Style="{StaticResource WindowControlButton}"
                            Click="MaxRestore_Click" ToolTip="Maximize/Restore"/>
                    <Button Content="&#xE8BB;" Style="{StaticResource CloseWindowButton}"
                            Click="Close_Click" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY: Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}">
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="NAVIGATION" FontSize="10" FontWeight="SemiBold"
                               FontFamily="Segoe UI" Foreground="#55FFFFFF"
                               Margin="24,0,0,12"/>

                    <Button Command="{Binding NavDataCaptureCommand}" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8D7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Data Capture" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding NavViewDataCommand}" Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="View Data" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Bottom: version -->
                    <TextBlock Text="v1.0.0" FontSize="10" FontFamily="Segoe UI"
                               Foreground="#33FFFFFF" Margin="24,0,0,16"
                               VerticalAlignment="Bottom"/>
                </StackPanel>
            </Border>

            <!-- CONTENT AREA -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentPage}"
                            Background="{StaticResource SurfaceBrush}"/>
        </Grid>
    </Grid>
</Window>
