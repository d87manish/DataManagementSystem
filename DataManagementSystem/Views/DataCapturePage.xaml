<UserControl x:Class="DataManagementSystem.Views.DataCapturePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:DataManagementSystem.Helpers"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter       x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Start/Stop button row -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="Auto"/>  <!-- Last 3 captures header -->
            <RowDefinition Height="Auto"/>  <!-- Last 3 stat cards -->
            <RowDefinition Height="Auto"/>  <!-- Divider -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- START / STOP BUTTON -->
        <Border Grid.Row="0" Padding="0,28,0,20" HorizontalAlignment="Center">
            <StackPanel HorizontalAlignment="Center">
                <!-- START button -->
                <Button Visibility="{Binding IsNotCapturing, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding StartCaptureCommand}"
                        Width="260" Height="64"
                        FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                        Foreground="White" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{StaticResource AccentGradient}"
                                    CornerRadius="14" SnapsToDevicePixels="True"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="3" Opacity="0.25" BlurRadius="14" Color="#3B82F6"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="START CAPTURE" FontSize="16" FontWeight="Bold"
                                               FontFamily="Segoe UI" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value><ScaleTransform ScaleX="1.03" ScaleY="1.03"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- STOP button -->
                <Button Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}"
                        Command="{Binding StopCaptureCommand}"
                        Width="260" Height="64"
                        FontSize="18" FontWeight="Bold" FontFamily="Segoe UI"
                        Foreground="White" Cursor="Hand" BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{StaticResource DangerGradient}"
                                    CornerRadius="14" SnapsToDevicePixels="True"
                                    RenderTransformOrigin="0.5,0.5">
                                <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect ShadowDepth="3" Opacity="0.25" BlurRadius="14" Color="#EF4444"/>
                                </Border.Effect>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                               Foreground="White" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="STOP CAPTURE" FontSize="16" FontWeight="Bold"
                                               FontFamily="Segoe UI" Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value><ScaleTransform ScaleX="1.03" ScaleY="1.03"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="RenderTransform">
                                        <Setter.Value><ScaleTransform ScaleX="0.97" ScaleY="0.97"/></Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>

        <!-- STATUS MESSAGE -->
        <Border Grid.Row="1" Margin="24,0,24,16" Padding="14,10" CornerRadius="8">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="#EFF6FF"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasStatusError}" Value="True">
                            <Setter Property="Background" Value="#FEF2F2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" FontFamily="Segoe UI">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasStatusError}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- LAST 3 CAPTURES HEADER -->
        <TextBlock Grid.Row="2" Text="LAST 3 CAPTURES" FontSize="11" FontWeight="SemiBold"
                   FontFamily="Segoe UI" Foreground="{StaticResource SubtleTextBrush}"
                   Margin="24,0,24,10"/>

        <!-- LAST 3 STAT CARDS -->
        <ItemsControl Grid.Row="3" ItemsSource="{Binding RecentCaptures}" Margin="24,0,24,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" Columns="3"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource StatCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="SERIAL NUMBER" FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SerialNumber}" FontSize="18" FontWeight="Bold"
                                       FontFamily="Segoe UI" Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="MODEL" FontSize="10" FontWeight="SemiBold"
                                       FontFamily="Segoe UI" Foreground="{StaticResource SubtleTextBrush}"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding ModelNumber}" FontSize="14"
                                       FontFamily="Segoe UI" Foreground="{StaticResource DarkTextBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CaptureDateDisplay}" FontSize="11"
                                       FontFamily="Segoe UI" Foreground="{StaticResource SubtleTextBrush}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- DIVIDER -->
        <Border Grid.Row="4" Style="{StaticResource SectionDivider}" Margin="24,16"/>

        <!-- DATA GRID -->
        <Grid Grid.Row="5" Margin="24,0,24,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="CAPTURED RECORDS (This Session)"
                       FontSize="11" FontWeight="SemiBold" FontFamily="Segoe UI"
                       Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,8"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding AllCaptures}"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridHeader}"
                      RowStyle="{StaticResource DataGridRowHover}"
                      CellStyle="{StaticResource DataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"             Binding="{Binding Id}"                Width="60"/>
                    <DataGridTextColumn Header="Serial Number"  Binding="{Binding SerialNumber}"       Width="160"/>
                    <DataGridTextColumn Header="Model Number"   Binding="{Binding ModelNumber}"        Width="130"/>
                    <DataGridTextColumn Header="Capture Date"   Binding="{Binding CaptureDateDisplay}" Width="120"/>
                    <DataGridTextColumn Header="Saved At"       Binding="{Binding CreatedOnIst}"       Width="*"/>
                    <DataGridTextColumn Header="Captured By"    Binding="{Binding CreatedByName}"      Width="120"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
