<UserControl x:Class="DataManagementSystem.Views.ViewDataPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:DataManagementSystem.Helpers"
             Background="{StaticResource SurfaceBrush}">

    <UserControl.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>

    <Grid Margin="24,20,24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Page title -->
            <RowDefinition Height="Auto"/>  <!-- Filter row -->
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
        </Grid.RowDefinitions>

        <!-- Page title -->
        <TextBlock Grid.Row="0" Text="View Data" FontSize="22" FontWeight="Bold"
                   FontFamily="Segoe UI" Foreground="{StaticResource DarkTextBrush}"
                   Margin="0,0,0,20"/>

        <!-- FILTER CARD -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="20,16" Margin="0,0,0,16">
            <StackPanel>

                <!-- Row 1: Date range + action buttons -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="From" Style="{StaticResource InputLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}"
                             Tag="yyyy-MM-dd"/>

                    <TextBlock Grid.Column="3" Text="To" Style="{StaticResource InputLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="4" Text="{Binding ToDate, UpdateSourceTrigger=PropertyChanged}"
                             Tag="yyyy-MM-dd"/>

                    <Button Grid.Column="6" Content="&#xE721;  Search" Style="{StaticResource PrimaryButton}"
                            Padding="16,9" Command="{Binding LoadCommand}"/>

                    <Button Grid.Column="8" Content="&#xE74E;  Export CSV"
                            Style="{StaticResource SecondaryButton}"
                            Padding="16,9" Command="{Binding ExportCsvCommand}"/>
                </Grid>

                <!-- Row 2: Text search filters -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Serial No." Style="{StaticResource InputLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="1" Text="{Binding Serial, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search serial number..."/>

                    <TextBlock Grid.Column="3" Text="Model" Style="{StaticResource InputLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Grid.Column="4" Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Search model number..."/>
                </Grid>

            </StackPanel>
        </Border>

        <!-- STATUS -->
        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}"
                   Visibility="{Binding HasStatus, Converter={StaticResource BoolToVisibility}}"
                   FontSize="12" FontFamily="Segoe UI" Foreground="{StaticResource SubtleTextBrush}"
                   Margin="0,0,0,12"/>

        <!-- DATA GRID -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Records}"
                      Style="{StaticResource ModernDataGrid}"
                      ColumnHeaderStyle="{StaticResource DataGridHeader}"
                      RowStyle="{StaticResource DataGridRowHover}"
                      CellStyle="{StaticResource DataGridCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"             Binding="{Binding Id}"                Width="70"/>
                    <DataGridTextColumn Header="Serial Number"  Binding="{Binding SerialNumber}"       Width="180"/>
                    <DataGridTextColumn Header="Model Number"   Binding="{Binding ModelNumber}"        Width="150"/>
                    <DataGridTextColumn Header="Capture Date"   Binding="{Binding CaptureDateDisplay}" Width="130"/>
                    <DataGridTextColumn Header="Created On"       Binding="{Binding CreatedOnIst}"      Width="*"/>
                    <DataGridTextColumn Header="Captured By"    Binding="{Binding CreatedByName}"      Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
